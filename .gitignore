# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
*.egg-info/
build/
dist/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Heavy binary outputs banned globally — committed run artifacts should be the
# human-readable CSV / JSON / JSONL trail, not embedding caches or model files.
*.parquet
*.npy
*.faiss
*.idx
*.bin
*.safetensors
*.pt
*.h5

# Misc transient
*.checksum
.tagclean/
*.log
.claude/

# Per-run cleaning artifacts. Stages 0-9 + repair write big intermediate
# state (parquet, npy, FAISS indexes, per-iter ops jsonl). The deliverable
# is the cleaned CSV at repo root; everything else regenerates on demand.
runs/
artifacts/
.last_run/

# Editor / IDE leftovers
.mypy_cache/
.ipynb_checkpoints/
Thumbs.db
